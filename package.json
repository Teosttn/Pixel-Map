{
  "name": "pixel-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "news:fetch": "node scripts/fetch-news.mjs",
    "test:markdown": "node scripts/check-markdown-codeblocks.mjs",
    "test:news": "node --test scripts/news/*.test.mjs",
    "test:content": "node scripts/check-news-content.mjs",
    "test:map": "node scripts/check-isometric-map.mjs",
    "test:motion": "node scripts/check-route-transitions.mjs",
    "test:visual-motion": "node scripts/check-visual-motion.mjs",
    "typecheck": "tsc --noEmit",
    "admin": "vite --config admin/vite.config.mjs",
